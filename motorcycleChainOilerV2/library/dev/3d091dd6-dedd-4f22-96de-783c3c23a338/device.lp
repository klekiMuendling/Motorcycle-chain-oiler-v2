(librepcb_device 3d091dd6-dedd-4f22-96de-783c3c23a338
 (name "AO4407A")
 (description "The AO4407A uses advanced trench technology to \nprovide excellent RDS(ON), and ultra-low low gate charge \nwith a 25V gate rating. This device is suitable for use as \na load switch or in PWM applications. \n\nVDS = -30V\nID = -12A (VGS = -20V) \nRDS(ON) < 11mΩ (VGS = -20V) \nRDS(ON) < 13mΩ (VGS = -10V) \nRDS(ON) < 17mΩ (VGS = -6V)")
 (keywords "MOSFET, P-channel, MOS, FET")
 (author "P.Klekot")
